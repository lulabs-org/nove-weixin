page {
  height: 100vh;
  background-color: #f1f1f1;
  display: flex;
  flex-direction: column;
}

.chat-container {
  flex: 1;
  box-sizing: border-box;
  padding-bottom: 20rpx;
}

.message-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.message-item {
  display: flex;
  margin-bottom: 20rpx;
  width: 100%;
}

.user-message {
  justify-content: flex-end;
}

.ai-message {
  justify-content: flex-start;
}

.bubble {
  padding: 20rpx;
  border-radius: 10rpx;
  max-width: 70%;
  font-size: 30rpx;
  line-height: 1.4;
  word-wrap: break-word;
}

.user-message .bubble {
  background-color: #dcdcdc; /* Gray background for user */
  color: #000;
}

.ai-message .bubble {
  background-color: transparent; /* No background for AI */
  color: #000;
  padding-left: 0; /* Align text to left edge */
}

.footer {
  position: fixed !important;
  bottom: 0 !important;
  left: 0 !important;
  width: 100% !important;
  background-color: transparent !important;
  display: flex !important;
  align-items: center !important;
  padding: 10rpx 30rpx !important;
  box-sizing: border-box !important;
  z-index: 100 !important;
  padding-bottom: calc(
    40rpx
  ) !important; /* Restore safe area and increase padding to move up */
}

.pill-wrapper {
  display: flex !important;
  flex: 1 !important;
  background-color: transparent !important; /* Fully transparent as requested */
  border-radius: 40rpx !important;
  padding: 10rpx 10rpx 10rpx 30rpx !important;
  align-items: flex-end !important;
  min-height: 80rpx !important;
  box-sizing: border-box !important;
  border: 2rpx solid #dcdcdc !important; /* Slightly more visible border since background is gone */
}

.chat-input {
  flex: 1;
  min-height: 60rpx;
  max-height: 240rpx;
  font-size: 30rpx;
  line-height: 40rpx;
  padding: 10rpx 0;
  color: #1a1a1a;
  box-sizing: border-box;
  background-color: transparent !important; /* Ensure no white background in input */
}

.send-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #e5e5e5; /* Disabled color */
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  margin-left: 20rpx;
  flex-shrink: 0;
  margin-bottom: 2rpx;
}

.send-btn.active {
  background-color: #000000; /* ChatGPT black active button */
}

.arrow-up {
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 16rpx solid #ffffff;
  position: relative;
  top: -2rpx;
}

.send-btn.active .arrow-up {
  border-bottom-color: #ffffff;
}
