page {
  height: 100vh;
  background-color: #f1f1f1;
  display: flex;
  flex-direction: column;
}

.chat-container {
  flex: 1;
  box-sizing: border-box;
  padding-bottom: 20rpx;
}

.message-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.message-item {
  display: flex;
  margin-bottom: 20rpx;
  width: 100%;
}

.user-message {
  justify-content: flex-end;
}

.ai-message {
  justify-content: flex-start;
}

.bubble {
  padding: 20rpx;
  border-radius: 10rpx;
  max-width: 70%;
  font-size: 30rpx;
  line-height: 1.4;
  word-wrap: break-word;
}

.user-message .bubble {
  background-color: #dcdcdc; /* Gray background for user */
  color: #000;
}

.ai-message .bubble {
  background-color: transparent; /* No background for AI */
  color: #000;
  padding-left: 0; /* Align text to left edge */
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  min-height: 120rpx;
  background-color: #f5f5f5;
  border-top: 1rpx solid #e5e5e5;
  display: flex;
  align-items: flex-end;
  padding: 20rpx;
  box-sizing: border-box;
  z-index: 100;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.input-container {
  flex: 1;
  margin-right: 20rpx;
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
}

.chat-input {
  width: 100%;
  min-height: 40rpx;
  max-height: 200rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  box-sizing: border-box;
}

.send-btn {
  width: 140rpx !important;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #07c160;
  color: white;
  font-size: 28rpx;
  padding: 0;
  border-radius: 8rpx;
  font-weight: normal;
  margin: 0;
  margin-bottom: 4rpx; /* Align with input better */
}
