page {
  height: 100vh;
  background-color: #f1f1f1;
  display: flex;
  flex-direction: column;
}

.chat-container {
  flex: 1;
  box-sizing: border-box;
  padding-bottom: 20rpx;
}

.message-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.message-item {
  display: flex;
  margin-bottom: 20rpx;
  width: 100%;
}

.user-message {
  justify-content: flex-end;
}

.ai-message {
  justify-content: flex-start;
}

.bubble {
  padding: 20rpx;
  border-radius: 10rpx;
  max-width: 70%;
  font-size: 30rpx;
  line-height: 1.4;
  word-wrap: break-word;
}

.user-message .bubble {
  background-color: #dcdcdc; /* Gray background for user */
  color: #000;
}

.ai-message .bubble {
  background-color: transparent; /* No background for AI */
  color: #000;
  padding-left: 0; /* Align text to left edge */
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: transparent; /* Remove white background */
  display: flex;
  align-items: center;
  padding: 10rpx 30rpx; /* Reduced top padding to move pill down */
  box-sizing: border-box;
  z-index: 100;
  padding-bottom: calc(
    16rpx + env(safe-area-inset-bottom)
  ); /* Optimized distance from R-angle */
}

.pill-wrapper {
  display: flex;
  flex: 1;
  background-color: #f4f4f4;
  border-radius: 40rpx;
  padding: 10rpx 10rpx 10rpx 30rpx;
  align-items: flex-end;
  min-height: 80rpx;
  box-sizing: border-box;
  border: 1rpx solid #e5e5e5;
}

.chat-input {
  flex: 1;
  min-height: 60rpx;
  max-height: 240rpx;
  font-size: 30rpx;
  line-height: 40rpx;
  padding: 10rpx 0;
  color: #1a1a1a;
  box-sizing: border-box;
}

.send-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #e5e5e5; /* Disabled color */
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  margin-left: 20rpx;
  flex-shrink: 0;
  margin-bottom: 2rpx;
}

.send-btn.active {
  background-color: #000000; /* ChatGPT black active button */
}

.arrow-up {
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 16rpx solid #ffffff;
  position: relative;
  top: -2rpx;
}

.send-btn.active .arrow-up {
  border-bottom-color: #ffffff;
}
