<scroll-view class="chat-container" scroll-y="true" scroll-into-view="{{toView}}" scroll-with-animation="true">
  <view class="message-list">
    <block wx:for="{{messages}}" wx:key="id">
      <view class="message-item {{item.role === 'user' ? 'user-message' : 'ai-message'}}" id="msg-{{item.id}}">
        <view class="bubble">
          <rich-text wx:if="{{item.html}}" nodes="{{item.html}}" user-select="true"></rich-text>
          <text wx:else user-select="true">{{item.text}}</text>
        </view>
      </view>
    </block>
    <!-- 底部占位，高度需大于输入框，防止消息被遮挡 -->
    <view id="scroll-bottom" style="height: 140rpx;"></view>
  </view>
</scroll-view>

<view class="footer">
  <view class="pill-wrapper">
    <textarea class="chat-input" value="{{inputValue}}" bindinput="onInput" confirm-type="send" bindconfirm="onSend" cursor-spacing="20" placeholder="Message ChatGPT..." auto-height="true" fixed="true" disable-default-padding="true" maxlength="2000" />
    <view class="send-btn {{inputValue ? 'active' : ''}}" bindtap="onSend">
      <view class="arrow-up"></view>
    </view>
  </view>
</view>
